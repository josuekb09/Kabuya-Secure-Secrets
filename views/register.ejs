<%- include('partials/header') %>

<div class="glass-container">
  <i class="fas fa-user-plus fa-4x mb-3"></i>
  <h1>Register</h1>
  <p>Join our community of anonymous secrets.</p>

  <form action="/register" method="POST">
    <input type="email" class="form-control-custom" name="username" placeholder="Email" required>
    <input type="password" class="form-control-custom" name="password" placeholder="Password" required>
    <button type="submit" class="btn-custom btn-light-custom w-100 mt-2">Create Account</button>
  </form>
</div>

<%- include('partials/footer') %>