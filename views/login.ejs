<%- include('partials/header') %>

<div class="glass-container">
  <i class="fas fa-sign-in-alt fa-4x mb-3"></i>
  <h1>Login</h1>
  <p>Welcome back! Please enter your credentials.</p>

  <form action="/login" method="POST">
    <input type="email" class="form-control-custom" name="username" placeholder="Email" required>
    <input type="password" class="form-control-custom" name="password" placeholder="Password" required>
    <button type="submit" class="btn-custom btn-light-custom w-100 mt-2">Sign In</button>
  </form>
</div>

<%- include('partials/footer') %>